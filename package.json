{
  "name": "course-navigator",
  "version": "0.1.2",
  "private": true,
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "bash scripts/start.sh",
    "dev:api": "uv run uvicorn course_navigator.app:app --app-dir backend --host 127.0.0.1 --port 8000",
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:frontend": "vitest run",
    "test:backend": ".venv/bin/pytest backend/tests -q",
    "test:all": "npm run test:frontend && npm run test:backend",
    "preview": "vite preview --host 127.0.0.1",
    "launcher:dev": "npm --prefix launcher run tauri:dev",
    "launcher:build": "npm --prefix launcher run tauri:build",
    "launcher:dmg": "npm --prefix launcher run dmg",
    "launcher:test": "npm --prefix launcher run test",
    "launcher:web": "npm --prefix launcher run dev",
    "launcher:build:web": "npm --prefix launcher run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "hls.js": "^1.6.16",
    "lucide-react": "^0.561.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.0.3",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "jsdom": "^27.3.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
