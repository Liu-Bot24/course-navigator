# Course Navigator local settings
COURSE_NAVIGATOR_DATA_DIR=.course-navigator
COURSE_NAVIGATOR_WORKSPACE_DIR=course-navigator-workspace

# Optional model profile. You can also configure model profiles in the app.
COURSE_NAVIGATOR_LLM_BASE_URL=
COURSE_NAVIGATOR_LLM_API_KEY=
COURSE_NAVIGATOR_LLM_MODEL=
COURSE_NAVIGATOR_MODEL_PROFILES=
COURSE_NAVIGATOR_TRANSLATION_MODEL_ID=default
COURSE_NAVIGATOR_LEARNING_MODEL_ID=default
COURSE_NAVIGATOR_GLOBAL_MODEL_ID=default
COURSE_NAVIGATOR_ASR_MODEL_ID=default
COURSE_NAVIGATOR_STUDY_DETAIL_LEVEL=faithful
COURSE_NAVIGATOR_TASK_PARAMETERS=

# Optional ASR correction search validation.
COURSE_NAVIGATOR_ASR_SEARCH_ENABLED=false
COURSE_NAVIGATOR_ASR_SEARCH_PROVIDER=tavily
COURSE_NAVIGATOR_ASR_SEARCH_RESULT_LIMIT=5
COURSE_NAVIGATOR_TAVILY_BASE_URL=https://api.tavily.com
COURSE_NAVIGATOR_TAVILY_API_KEY=
COURSE_NAVIGATOR_FIRECRAWL_BASE_URL=
COURSE_NAVIGATOR_FIRECRAWL_API_KEY=

# Optional online ASR providers.
COURSE_NAVIGATOR_ONLINE_ASR_PROVIDER=none
COURSE_NAVIGATOR_OPENAI_ASR_API_KEY=
COURSE_NAVIGATOR_GROQ_ASR_API_KEY=
COURSE_NAVIGATOR_XAI_ASR_MODEL=grok-2-voice-1212
COURSE_NAVIGATOR_XAI_ASR_API_KEY=
COURSE_NAVIGATOR_CUSTOM_ASR_BASE_URL=
COURSE_NAVIGATOR_CUSTOM_ASR_MODEL=
COURSE_NAVIGATOR_CUSTOM_ASR_API_KEY=
COURSE_NAVIGATOR_ASR_CACHE_AUTO_CLEANUP_ENABLED=true

# Optional dev server ports.
COURSE_NAVIGATOR_API_HOST=127.0.0.1
COURSE_NAVIGATOR_API_PORT=8000
COURSE_NAVIGATOR_WEB_HOST=127.0.0.1
COURSE_NAVIGATOR_WEB_PORT=5173
