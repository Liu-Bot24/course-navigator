{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Course Navigator",
  "version": "0.1.3",
  "identifier": "com.course-navigator.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Course Navigator",
        "width": 1000,
        "height": 800,
        "minWidth": 900,
        "minHeight": 740,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "category": "Education",
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "resources": {
      "resources/runtime-source": "runtime-source"
    }
  }
}
